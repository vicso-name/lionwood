{
  "name": "lionwood",
  "version": "1.0.3",
  "description": "This is the gulp starter kit for WordPress theme and plugin development purposes.",
  "main": "index.js",
  "scripts": {
    "dev": "gulp",
    "build": "cross-env NODE_ENV=production gulp build",
    "new-section": "node generate-sections.js",
    "new-section:js": "node generate-sections.js --js",
    "lint": "npm run lint:scss && npm run lint:js",
    "lint:scss": "stylelint \"src/scss/**/*.scss\"",
    "lint:scss:fix": "stylelint \"src/scss/**/*.scss\" --fix",
    "lint:js": "eslint \"src/js/**/*.js\"",
    "setup": "node scripts/setup.mjs"
  },
  "keywords": [
    "gulp",
    "wordpress",
    "theme"
  ],
  "author": "VICSO",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "browser-sync": "^3.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.0",
    "gulp": "^5.0.0",
    "gulp-autoprefixer": "^9.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-concat": "^2.6.1",
    "gulp-if": "^3.0.0",
    "gulp-notify": "^5.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-rename": "^2.0.0",
    "gulp-sass": "^6.0.0",
    "gulp-terser": "^2.1.0",
    "sass": "^1.83.4",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0"
  },
  "dependencies": {
    "del": "^6.1.1",
    "glightbox": "^3.3.1",
    "isotope-layout": "^3.0.6",
    "swiper": "^11.2.1"
  }
}
